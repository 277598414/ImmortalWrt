/dts-v1/;
#include "mt7988d-tplink-tl-7dr-common.dtsi"

/ {
	model = "TP-Link TL-7DR7299 v1";
	compatible = "tplink,tl-7dr7299-v1", "mediatek,mt7988a";

	cpus {
		cpu3: cpu@3 {
			compatible = "arm,cortex-a73";
			reg = <0x3>;
			device_type = "cpu";
			enable-method = "psci";
			clocks = <&mcusys CLK_MCU_ARM_DIV_SEL>, <&topckgen CLK_TOP_XTAL>;
			clock-names = "cpu", "intermediate";
			operating-points-v2 = <&cluster0_opp>;
			mediatek,cci = <&cci>;
		};
	};

	gpio-leds {
		led-2 {
			color = <LED_COLOR_ID_GREEN>;
			function = "sfp";
			gpios = <&pio 81 GPIO_ACTIVE_LOW>;
		};
	};

	sfp0: sfp0 {
		compatible = "sff,sfp";
		i2c-bus = <&i2c1>;
		los-gpios = <&pio 82 GPIO_ACTIVE_HIGH>;
		mod-def0-gpios = <&pio 80 GPIO_ACTIVE_LOW>;
		tx-disable-gpios = <&pio 83 GPIO_ACTIVE_LOW>;
		maximum-power-milliwatt = <3000>;
	};
};

&cpu3 {
	proc-supply = <&rt5190_buck3>;
};

&gmac1 {
	nvmem-cells = <&macaddr_factory_1e001c 1>;
	nvmem-cell-names = "mac-address";
	phy-handle = <&phy1>;
	phy-mode = "usxgmii";

	/delete-property/ phy-connection-type;
	/delete-property/ phy;

	status = "okay";
};

&gmac2 {
	nvmem-cells = <&macaddr_factory_1e001c 0>;
	nvmem-cell-names = "mac-address";
	phy-mode = "10gbase-r";
	status = "okay";

	fixed-link {
		speed = <10000>;
		full-duplex;
		pause;
	};
};

&gsw_phy2 {
	pinctrl-names = "gbe-led";
	pinctrl-0 = <&gbe2_led0_pins>;
};

&gsw_phy2_led0 {
	function = LED_FUNCTION_LAN;
	color = <LED_COLOR_ID_GREEN>;
	status = "okay";
};

&gsw_phy3 {
	pinctrl-names = "gbe-led";
	pinctrl-0 = <&gbe3_led0_pins>;
};

&gsw_phy3_led0 {
	function = LED_FUNCTION_LAN;
	color = <LED_COLOR_ID_GREEN>;
	status = "okay";
};

&gsw_port0 {
	status = "disabled";
};

&gsw_port1 {
	status = "disabled";
};

&gsw_port2 {
	label = "lan1";
};

&gsw_port3 {
	label = "lan2";
};

&i2c1 {
	pinctrl-names = "default";
	pinctrl-0 = <&i2c1_pins>;
	status = "okay";
};

&mdio_bus {
	phy1: ethernet-phy@1 {
		compatible = "ethernet-phy-ieee802.3-c45";
		reg = <1>;
		reset-assert-us = <100000>;
		reset-deassert-us = <221000>;
		reset-gpios = <&pio 21 GPIO_ACTIVE_LOW>;

		leds {
			#address-cells = <1>;
			#size-cells = <0>;

			led@3 {
				reg = <3>;
				function = LED_FUNCTION_WAN;
				color = <LED_COLOR_ID_GREEN>;
				active-low;
			};
		};
	};

	rtl837x-gsw@1d {
		compatible = "realtek,rtl837x";
		reg = <29>;
		ethernet = <&gmac2>;
		reset-gpios = <&pio 57 GPIO_ACTIVE_HIGH>;
		rtl837x,cpu-port = <0>;
		rtl837x,sds0mode = "10g-kr";
		sfp = <&sfp0>;

		extra-init =
			/* LED_RLDP_CTRL_3~8_P2_LED3_0_RLDP */
			<0x65FC 0xffffffff 0x33333000>, // RTL8373_LED_RLDP_CTRL_2_ADDR
			<0x6600 0xf        0x3       >, // RTL8373_LED_RLDP_CTRL_3_ADDR
			/* 10m/100m/500m/1g/2p5g/link/act */
			<0x6548 0xffff     0x17D     >, // RTL8373_LED1_0_SET0_CTRL0_ADDR
			/* LED_GLB_MUX_1_CFG_PAD_LED3_MUX */
			<0x65E0 0xfc0000   0x10      >, // RTL8373_LED_GLB_MUX_1_ADDR
			/* LED_GLB_MUX_2_CFG_PAD_LED6_MUX */
			<0x65E4 0xfc0      0x14      >, // RTL8373_LED_GLB_MUX_2_ADDR
			/* LED_GLB_MUX_3_CFG_PAD_LED10_MUX */
			<0x65E8 0x3f       0x18      >, // RTL8373_LED_GLB_MUX_3_ADDR
			/* LED_GLB_MUX_4_CFG_PAD_LED18_MUX */
			<0x65EC 0xfc0000   0x1C      >, // RTL8373_LED_GLB_MUX_4_ADDR
			/* LED_GLB_ACTIVE_CFG_PAD_LED3_ACTIVE_LOW */
			<0x65D8 0x8        0         >, // RTL8373_LED_GLB_ACTIVE_ADDR
			/* LED_GLB_ACTIVE_CFG_PAD_LED6_ACTIVE_LOW */
			<0x65D8 0x6        0         >, // RTL8373_LED_GLB_ACTIVE_ADDR
			/* LED_GLB_ACTIVE_CFG_PAD_LED10_ACTIVE_LOW */
			<0x65D8 0xA        0         >, // RTL8373_LED_GLB_ACTIVE_ADDR
			/* LED_GLB_ACTIVE_CFG_PAD_LED18_ACTIVE_LOW */
			<0x65D8 0x12       0         >, // RTL8373_LED_GLB_ACTIVE_ADDR
			/* LED_GLB_IO_EN_CFG_PARA_LED3/6/10/18/28/29_IO_EN */
			<0x65DC 0x3fffffff 0x30040448>, // RTL8373_LED_GLB_IO_EN_ADDR
			/* IO_MUX_SEL_0_GPIO_LED3/6/10/18 */
			<0x7F8C 0x3fffffff 0x3FFBFBB7>, // RTL8373_IO_MUX_SEL_0_ADDR
			/* LED_GLB_CTRL_STP1_PWR_ON_LED */
			<0x6520 0x1E0      1         >, // RTL8373_LED_GLB_CTRL_ADDR
			/* LED_GLB_CTRL_STP2_PWR_ON_LED */
			<0x6520 0x1E00     0         >, // RTL8373_LED_GLB_CTRL_ADDR
			/* LED_GLB_CTRL_PWR_ON_BLINK_SEL */
			<0x6520 0x18       1         >; // RTL8373_LED_GLB_CTRL_ADDR
	};
};

&pio {
	gbe2_led0_pins: gbe2-led0-pins {
		mux {
			function = "led";
			groups = "gbe2_led0";
		};
	};

	gbe3_led0_pins: gbe3-led0-pins {
		mux {
			function = "led";
			groups = "gbe3_led0";
		};
	};

	i2c1_pins: i2c1-g0-pins {
		mux {
			function = "i2c";
			groups = "i2c1_0";
		};
	};
};

&ssusb1 {
	status = "okay";
};

&tphy {
	status = "okay";
};
